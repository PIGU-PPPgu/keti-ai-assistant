<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>课题 AI 助手</title>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        :root {
            --primary: #10a37f;
            --bg: #343541;
            --sidebar: #202123;
            --user-bg: #343541;
            --ai-bg: #444654;
            --text: #ececf1;
            --text-light: #c5c5d2;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            background: var(--bg);
            color: var(--text);
            height: 100vh;
            overflow: hidden;
        }
        
        .container {
            display: flex;
            height: 100vh;
        }
        
        /* 侧边栏 */
        .sidebar {
            width: 260px;
            background: var(--sidebar);
            display: flex;
            flex-direction: column;
            border-right: 1px solid rgba(255,255,255,0.1);
        }
        
        .sidebar-header {
            padding: 12px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }
        
        .new-chat {
            width: 100%;
            padding: 12px;
            background: transparent;
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 6px;
            color: var(--text);
            cursor: pointer;
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: background 0.2s;
        }
        
        .new-chat:hover {
            background: rgba(255,255,255,0.05);
        }
        
        .sidebar-content {
            flex: 1;
            overflow-y: auto;
            padding: 12px;
        }
        
        .agent-card {
            background: rgba(255,255,255,0.05);
            border-radius: 8px;
            padding: 12px;
            margin-bottom: 8px;
        }
        
        .agent-name {
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 4px;
        }
        
        .agent-status {
            font-size: 12px;
            color: var(--text-light);
        }
        
        .agent-status.active {
            color: var(--primary);
        }
        
        /* 主区域 */
        .main {
            flex: 1;
            display: flex;
            flex-direction: column;
        }
        
        /* 对话区域 */
        .chat {
            flex: 1;
            overflow-y: auto;
        }
        
        .message {
            padding: 24px 0;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }
        
        .message.user {
            background: var(--user-bg);
        }
        
        .message.assistant {
            background: var(--ai-bg);
        }
        
        .message-content {
            max-width: 768px;
            margin: 0 auto;
            padding: 0 24px;
            line-height: 1.75;
        }
        
        .message.user .message-content {
            display: flex;
            justify-content: flex-end;
        }
        
        .message-bubble {
            max-width: 70%;
        }
        
        .message.assistant .message-bubble {
            max-width: 100%;
        }
        
        .message h1, .message h2, .message h3 {
            margin: 20px 0 10px;
        }
        
        .message h1 { font-size: 24px; }
        .message h2 { font-size: 20px; }
        .message h3 { font-size: 16px; }
        
        .message p { margin: 12px 0; }
        
        .message ul, .message ol {
            margin: 12px 0;
            padding-left: 24px;
        }
        
        .message code {
            background: rgba(0,0,0,0.3);
            padding: 2px 6px;
            border-radius: 4px;
            font-family: monospace;
        }
        
        .message pre {
            background: rgba(0,0,0,0.3);
            padding: 16px;
            border-radius: 8px;
            overflow-x: auto;
            margin: 16px 0;
        }
        
        .message table {
            width: 100%;
            border-collapse: collapse;
            margin: 16px 0;
        }
        
        .message th, .message td {
            border: 1px solid rgba(255,255,255,0.2);
            padding: 8px 12px;
            text-align: left;
        }
        
        .message th {
            background: rgba(0,0,0,0.2);
        }
        
        /* Agent 提示 */
        .agent-hint {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 12px;
            font-size: 13px;
            color: var(--text-light);
        }
        
        .agent-hint .dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--primary);
            animation: pulse 1.5s infinite;
        }
        
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.4; }
        }
        
        /* 输入区域 */
        .input-area {
            padding: 24px;
            background: var(--bg);
            border-top: 1px solid rgba(255,255,255,0.1);
        }
        
        .input-container {
            max-width: 768px;
            margin: 0 auto;
        }
        
        .input-wrapper {
            display: flex;
            gap: 12px;
            background: #40414f;
            border-radius: 12px;
            padding: 12px;
            border: 1px solid rgba(255,255,255,0.1);
        }
        
        .input-wrapper textarea {
            flex: 1;
            background: transparent;
            border: none;
            color: var(--text);
            font-size: 15px;
            font-family: inherit;
            resize: none;
            max-height: 200px;
            outline: none;
        }
        
        .input-wrapper button {
            background: var(--primary);
            border: none;
            border-radius: 6px;
            padding: 8px 16px;
            color: white;
            cursor: pointer;
            font-size: 14px;
            transition: opacity 0.2s;
        }
        
        .input-wrapper button:hover {
            opacity: 0.9;
        }
        
        .input-wrapper button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }
        
        /* 快捷操作 */
        .quick-actions {
            display: flex;
            gap: 8px;
            margin-bottom: 12px;
            flex-wrap: wrap;
        }
        
        .quick-btn {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 16px;
            padding: 6px 12px;
            color: var(--text-light);
            cursor: pointer;
            font-size: 13px;
            transition: all 0.2s;
        }
        
        .quick-btn:hover {
            background: rgba(255,255,255,0.1);
            color: var(--text);
        }
        
        /* 操作按钮 */
        .actions {
            display: flex;
            gap: 8px;
            margin-top: 16px;
        }
        
        .action-btn {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 6px;
            padding: 8px 16px;
            color: var(--text-light);
            cursor: pointer;
            font-size: 13px;
            transition: all 0.2s;
        }
        
        .action-btn:hover {
            background: rgba(255,255,255,0.1);
            color: var(--text);
        }
        
        .action-btn.primary {
            background: var(--primary);
            border-color: var(--primary);
            color: white;
        }
        
        /* 加载动画 */
        .typing {
            display: flex;
            gap: 4px;
        }
        
        .typing span {
            width: 8px;
            height: 8px;
            background: var(--text-light);
            border-radius: 50%;
            animation: bounce 1s infinite;
        }
        
        .typing span:nth-child(2) { animation-delay: 0.2s; }
        .typing span:nth-child(3) { animation-delay: 0.4s; }
        
        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-6px); }
        }
        
        /* 用户状态区域 */
        .sidebar-footer {
            padding: 12px;
            border-top: 1px solid rgba(255,255,255,0.1);
        }
        
        .login-prompt {
            text-align: center;
        }
        
        .login-btn {
            width: 100%;
            padding: 10px;
            background: transparent;
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 6px;
            color: var(--text);
            cursor: pointer;
            font-size: 14px;
            transition: all 0.2s;
        }
        
        .login-btn:hover {
            background: rgba(255,255,255,0.05);
        }
        
        .user-info {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        
        .user-avatar {
            font-size: 24px;
            background: rgba(255,255,255,0.1);
            border-radius: 50%;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .user-details {
            flex: 1;
        }
        
        .user-name {
            font-weight: 600;
            font-size: 14px;
            margin-bottom: 4px;
        }
        
        .history-link {
            font-size: 12px;
            color: var(--text-light);
            text-decoration: none;
            transition: color 0.2s;
        }
        
        .history-link:hover {
            color: var(--text);
        }
        
        .logout-btn {
            padding: 6px 12px;
            background: transparent;
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 4px;
            color: var(--text-light);
            cursor: pointer;
            font-size: 12px;
            transition: all 0.2s;
        }
        
        .logout-btn:hover {
            background: rgba(255,255,255,0.1);
            color: var(--text);
        }
        
        @media (max-width: 768px) {
            .sidebar { display: none; }
            .message-bubble { max-width: 100%; }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="sidebar">
            <div class="sidebar-header">
                <button class="new-chat" onclick="newChat()">
                    新对话
                </button>
            </div>
            <div class="sidebar-content">
                <div class="agent-card">
                    <div class="agent-name">文献专家</div>
                    <div class="agent-status" id="status-literature">待命</div>
                </div>
                <div class="agent-card">
                    <div class="agent-name">写作专家</div>
                    <div class="agent-status" id="status-writer">待命</div>
                </div>
                <div class="agent-card">
                    <div class="agent-name">审核专家</div>
                    <div class="agent-status" id="status-reviewer">待命</div>
                </div>
            </div>
            
            <!-- 用户状态区域 -->
            <div class="sidebar-footer">
                <div id="userArea">
                    <!-- 未登录状态 -->
                    <div id="loginPrompt" class="login-prompt">
                        <button class="login-btn" onclick="window.location.href='/login.html'">登录 / 注册</button>
                    </div>
                    <!-- 已登录状态（默认隐藏） -->
                    <div id="userInfo" class="user-info" style="display: none;">
                        <div class="user-avatar">👤</div>
                        <div class="user-details">
                            <div class="user-name" id="userName">用户名</div>
                            <a href="/history.html" class="history-link">📜 历史记录</a>
                        </div>
                        <button class="logout-btn" onclick="logout()">退出</button>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="main">
            <div class="chat" id="chat">
                <div class="message assistant">
                    <div class="message-content">
                        <div class="message-bubble">
                            <p>你好！我是课题 AI 助手。</p>
                            <p>我可以帮你生成：</p>
                            <ul>
                                <li><strong>课题申报书</strong>（区级/市级/省级）</li>
                                <li><strong>开题报告</strong></li>
                                <li><strong>中期检查报告</strong></li>
                                <li><strong>结题报告</strong></li>
                            </ul>
                            <p>直接告诉我你想生成什么，比如：</p>
                            <p><em>"帮我生成一个市级数学课题申报书，研究方向是核心素养"</em></p>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="input-area">
                <div class="input-container">
                    <div class="quick-actions">
                        <button class="quick-btn" onclick="quick('市级数学课题申报书，核心素养')">市级数学 · 核心素养</button>
                        <button class="quick-btn" onclick="quick('区级语文课题申报书')">区级语文课题</button>
                        <button class="quick-btn" onclick="quick('省级英语课题申报书')">省级英语课题</button>
                    </div>
                    
                    <div class="input-wrapper">
                        <textarea 
                            id="input"
                            placeholder="输入你的需求..."
                            rows="1"
                            onkeydown="if(event.key==='Enter' && !event.shiftKey){event.preventDefault();send()}"
                        ></textarea>
                        <button onclick="send()" id="sendBtn">发送</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <script>
        marked.setOptions({ breaks: true, gfm: true });
        
        let sessionId = 'session_' + Date.now();
        let generatedContent = '';
        let currentDocumentTitle = '';
        
        // 用户状态管理
        function checkUserStatus() {
            const token = localStorage.getItem('token');
            const user = JSON.parse(localStorage.getItem('user') || 'null');
            
            const loginPrompt = document.getElementById('loginPrompt');
            const userInfo = document.getElementById('userInfo');
            const userName = document.getElementById('userName');
            
            if (token && user) {
                loginPrompt.style.display = 'none';
                userInfo.style.display = 'flex';
                userName.textContent = user.username;
            } else {
                loginPrompt.style.display = 'block';
                userInfo.style.display = 'none';
            }
        }
        
        function logout() {
            localStorage.removeItem('token');
            localStorage.removeItem('user');
            checkUserStatus();
        }
        
        function getAuthHeaders() {
            const token = localStorage.getItem('token');
            const headers = { 'Content-Type': 'application/json' };
            if (token) {
                headers['Authorization'] = `Bearer ${token}`;
            }
            return headers;
        }
        
        // 页面加载时检查用户状态
        checkUserStatus();
        
        function quick(text) {
            document.getElementById('input').value = text;
            send();
        }
        
        async function send() {
            const input = document.getElementById('input');
            const message = input.value.trim();
            
            if (!message) return;
            
            addMessage('user', message);
            input.value = '';
            document.getElementById('sendBtn').disabled = true;
            
            try {
                // 调用 API（携带认证 token）
                const res = await fetch('/api/chat', {
                    method: 'POST',
                    headers: getAuthHeaders(),
                    body: JSON.stringify({ message, sessionId })
                });
                
                const data = await res.json();
                
                if (data.success) {
                    if (data.sessionId) sessionId = data.sessionId;
                    handleResponse(data);
                } else {
                    addMessage('assistant', '抱歉，出错了：' + data.error);
                }
            } catch (e) {
                addMessage('assistant', '网络错误，请稍后重试');
            }
            
            document.getElementById('sendBtn').disabled = false;
        }
        
        function handleResponse(data) {
            switch (data.type) {
                case 'message':
                    addMessage('assistant', data.content);
                    break;
                    
                case 'question':
                    addMessage('assistant', data.content, true, data.options);
                    break;
                    
                case 'start_generation':
                    startGeneration(data);
                    break;
            }
        }
        
        async function startGeneration(data) {
            const { params, documentType } = data;
            currentDocumentTitle = params.title || getDocName(documentType);
            
            // 启动状态轮询
            const statusInterval = setInterval(async () => {
                try {
                    const res = await fetch('/api/agents/status');
                    const result = await res.json();
                    if (result.success) {
                        result.agents.forEach(agent => {
                            const el = document.getElementById(`status-${agent.name === '文献专家' ? 'literature' : agent.name === '写作专家' ? 'writer' : 'reviewer'}`);
                            if (el) {
                                el.textContent = agent.status === 'working' ? agent.currentTask : agent.status;
                                el.className = 'agent-status' + (agent.status === 'working' ? ' active' : '');
                            }
                        });
                    }
                } catch (e) {
                    // 忽略错误
                }
            }, 500);
            
            addMessage('assistant', `好的，我开始为你生成${getDocName(documentType)}。\n\n正在协调多个专家Agent...`);
            
            try {
                // 调用生成 API（携带认证 token）
                const res = await fetch('/api/generate-with-params', {
                    method: 'POST',
                    headers: getAuthHeaders(),
                    body: JSON.stringify({ sessionId, documentType, params })
                });
                
                const result = await res.json();
                
                clearInterval(statusInterval);
                
                if (result.success) {
                    generatedContent = result.content;
                    
                    // 显示生成结果
                    const cleanContent = result.content
                        .replace(/```markdown\n?/gi, '')
                        .replace(/```\n?/g, '');
                    
                    const html = `
                        ${marked.parse(cleanContent.substring(0, 3000))}
                        
                        <p><em>（共 ${result.wordCount} 字，已截取前 3000 字预览）</em></p>
                        
                        <div class="actions">
                            <button class="action-btn primary" onclick="humanize()">去AI化润色</button>
                            <button class="action-btn" onclick="copy()">复制全文</button>
                            <button class="action-btn" onclick="downloadWord()">下载Word</button>
                        </div>
                    `;
                    
                    addMessage('assistant', html, true);
                } else {
                    addMessage('assistant', '生成失败：' + result.error);
                }
            } catch (e) {
                clearInterval(statusInterval);
                addMessage('assistant', '生成失败，请稍后重试');
            }
        }
        
        async function humanize() {
            if (!generatedContent) return;
            
            updateAgentStatus('reviewer', '润色中...');
            addMessage('assistant', '审核专家正在进行去AI化润色...');
            
            try {
                const res = await fetch('/api/humanize', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ content: generatedContent })
                });
                
                const result = await res.json();
                
                if (result.success) {
                    updateAgentStatus('reviewer', '完成');
                    generatedContent = result.content;
                    
                    addMessage('assistant', `去AI化完成！\n\n原文 ${result.wordCount} 字已被润色，更像人类写作了。`, true);
                } else {
                    addMessage('assistant', '润色失败：' + result.error);
                }
            } catch (e) {
                addMessage('assistant', '润色失败，请稍后重试');
            }
        }
        
        function copy() {
            if (generatedContent) {
                navigator.clipboard.writeText(generatedContent);
                alert('已复制到剪贴板！');
            }
        }
        
        async function downloadWord() {
            if (!generatedContent) return;
            
            try {
                const res = await fetch('/api/export-word', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        content: generatedContent,
                        title: currentDocumentTitle
                    })
                });
                
                const blob = await res.blob();
                const url = URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = `${currentDocumentTitle}.docx`;
                a.click();
            } catch (e) {
                alert('下载失败');
            }
        }
        
        function newChat() {
            sessionId = 'session_' + Date.now();
            generatedContent = '';
            document.getElementById('chat').innerHTML = `
                <div class="message assistant">
                    <div class="message-content">
                        <div class="message-bubble">
                            <p>新的对话已开始。你需要生成什么？</p>
                        </div>
                    </div>
                </div>
            `;
            updateAgentStatus('literature', '待命');
            updateAgentStatus('writer', '待命');
            updateAgentStatus('reviewer', '待命');
        }
        
        function addMessage(role, content, isMarkdown = false, options = null) {
            const chat = document.getElementById('chat');
            const div = document.createElement('div');
            div.className = `message ${role}`;
            
            let html = '';
            if (isMarkdown) {
                html = marked.parse(content.replace(/```markdown\n?/gi, '').replace(/```\n?/g, ''));
            } else {
                html = content.replace(/\n/g, '<br>');
            }
            
            if (options && options.length > 0) {
                html += '<div class="actions">';
                options.forEach(opt => {
                    html += `<button class="action-btn" onclick="selectOption('${opt}')">${opt}</button>`;
                });
                html += '</div>';
            }
            
            div.innerHTML = `
                <div class="message-content">
                    <div class="message-bubble">${html}</div>
                </div>
            `;
            
            chat.appendChild(div);
            chat.scrollTop = chat.scrollHeight;
        }
        
        function selectOption(option) {
            document.getElementById('input').value = option;
            send();
        }
        
        function updateAgentStatus(agent, status) {
            const el = document.getElementById(`status-${agent}`);
            if (el) {
                el.textContent = status;
                el.className = 'agent-status' + (status === '待命' ? '' : ' active');
            }
        }
        
        function getDocName(type) {
            const names = {
                shenbao: '课题申报书',
                kaiti: '开题报告',
                zhongqi: '中期检查报告',
                jieti: '结题报告'
            };
            return names[type] || type;
        }
        
        // 自动调整输入框高度
        document.getElementById('input').addEventListener('input', function() {
            this.style.height = 'auto';
            this.style.height = Math.min(this.scrollHeight, 200) + 'px';
        });
    </script>
</body>
</html>
