# 环境变量配置

# AI 配置（必填）
AI_API_KEY=your_api_key_here

# AI Provider 切换（可选，默认 glm）
# 选项: glm | deepseek | openai
AI_PROVIDER=glm

# 模型选择（可选）
# GLM: glm-4-plus, glm-4-flash, glm-4-air
# DeepSeek: deepseek-chat, deepseek-reasoner
# OpenAI: gpt-4o, gpt-4o-mini
AI_MODEL=glm-4-plus

# JWT 密钥（必填，至少32位随机字符串）
JWT_SECRET=your_jwt_secret_at_least_32_chars_here

# 数据库路径（可选）
DB_PATH=./data/keti.db

# 服务端口（可选，默认3000）
PORT=3000

# 环境（development | production）
NODE_ENV=development

# 允许的跨域来源（生产环境填写）
# ALLOWED_ORIGINS=https://yourdomain.com

# 文献搜索（可选，有则启用联网搜索真实文献）
# 申请地址：https://tavily.com（免费额度 1000次/月）
# TAVILY_API_KEY=tvly-xxxxx
